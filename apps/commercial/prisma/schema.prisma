generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum CommercialItemType {
  PRODUCT
  SERVICE
}

enum ProposalStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  ARCHIVED
}

enum ProposalVersionStatus {
  DRAFT
  PUBLISHED
  LOCKED
}

enum ProposalAuditAction {
  CREATED
  UPDATED
  VERSION_PUBLISHED
  PUBLIC_LINK_CREATED
  PUBLIC_LINK_REVOKED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  profileId    String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model CommercialProfile {
  id                      String   @id @default(cuid())
  slug                    String   @unique
  name                    String
  maxFinalPriceAdjustment Int      @default(0)
  canManageCatalog        Boolean  @default(false)
  canManageProposals      Boolean  @default(false)
  canManageUsers          Boolean  @default(false)
  isSystem                Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model CommercialItem {
  id            String             @id @default(cuid())
  code          String             @unique
  name          String
  description   String?
  category      String
  type          CommercialItemType
  unitPrice     Float
  active        Boolean            @default(true)
  createdById   String
  updatedById   String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Proposal {
  id              String             @id @default(cuid())
  number          String             @unique
  title           String
  customerName    String
  customerEmail   String?
  status          ProposalStatus     @default(DRAFT)
  currentRevision Int                @default(1)
  createdById     String
  updatedById     String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model ProposalVersion {
  id             String                @id @default(cuid())
  proposalId     String
  revisionNumber Int
  label          String
  status         ProposalVersionStatus @default(DRAFT)
  notes          String?
  createdById    String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([proposalId, revisionNumber])
}

model ProposalSection {
  id                String          @id @default(cuid())
  proposalVersionId String
  title             String
  description       String?
  position          Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([proposalVersionId, position])
}

model ProposalItem {
  id                String          @id @default(cuid())
  proposalSectionId String
  commercialItemId  String?
  name              String
  description       String?
  quantity          Float
  unitPrice         Float
  discountPercent   Float           @default(0)
  position          Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([proposalSectionId, position])
}

model ProposalPublicLink {
  id                String          @id @default(cuid())
  proposalVersionId String
  token             String          @unique
  expiresAt         DateTime?
  revokedAt         DateTime?
  accessCount       Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model ProposalAuditLog {
  id                String              @id @default(cuid())
  proposalId        String
  proposalVersionId String?
  userId            String?
  action            ProposalAuditAction
  message           String
  details           String?
  createdAt         DateTime            @default(now())
}
