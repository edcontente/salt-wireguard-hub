generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model CommercialProfile {
  id                      String   @id @default(cuid())
  slug                    String   @unique
  name                    String
  maxFinalPriceAdjustment Int      @default(0)
  canManageCatalog        Boolean  @default(false)
  canManageProposals      Boolean  @default(false)
  canManageUsers          Boolean  @default(false)
  isSystem                Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  users                   User[]   @relation("CommercialProfileUsers")
}

model User {
  id                      String             @id @default(cuid())
  name                    String
  email                   String             @unique
  passwordHash            String
  status                  String             @default("ACTIVE")
  profileId               String
  profile                 CommercialProfile  @relation("CommercialProfileUsers", fields: [profileId], references: [id])
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  commercialItemsCreated  CommercialItem[]   @relation("CommercialItemCreatedBy")
  commercialItemsUpdated  CommercialItem[]   @relation("CommercialItemUpdatedBy")
  proposalsCreated        Proposal[]         @relation("ProposalCreatedBy")
  proposalsUpdated        Proposal[]         @relation("ProposalUpdatedBy")
  proposalVersionsCreated ProposalVersion[]  @relation("ProposalVersionCreatedBy")
  proposalAuditLogs       ProposalAuditLog[] @relation("ProposalAuditLogUser")
}

model CommercialItem {
  id            String             @id @default(cuid())
  code          String             @unique
  name          String
  description   String?
  category      String
  type          String
  unitPrice     Float
  active        Boolean            @default(true)
  createdById   String
  updatedById   String
  createdBy     User               @relation("CommercialItemCreatedBy", fields: [createdById], references: [id])
  updatedBy     User               @relation("CommercialItemUpdatedBy", fields: [updatedById], references: [id])
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  proposalItems ProposalItem[]
}

model Proposal {
  id              String             @id @default(cuid())
  number          String             @unique
  title           String
  customerName    String
  customerEmail   String?
  status          String             @default("DRAFT")
  currentRevision Int                @default(1)
  createdById     String
  updatedById     String
  createdBy       User               @relation("ProposalCreatedBy", fields: [createdById], references: [id])
  updatedBy       User               @relation("ProposalUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  versions        ProposalVersion[]
  auditLogs       ProposalAuditLog[]
}

model ProposalVersion {
  id             String                @id @default(cuid())
  proposalId     String
  revisionNumber Int
  label          String
  status         String                @default("DRAFT")
  notes          String?
  createdById    String
  proposal       Proposal              @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdBy      User                  @relation("ProposalVersionCreatedBy", fields: [createdById], references: [id])
  sections       ProposalSection[]
  publicLinks    ProposalPublicLink[]
  auditLogs      ProposalAuditLog[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([proposalId, revisionNumber])
}

model ProposalSection {
  id                String          @id @default(cuid())
  proposalVersionId String
  title             String
  description       String?
  position          Int
  proposalVersion   ProposalVersion @relation(fields: [proposalVersionId], references: [id], onDelete: Cascade)
  items             ProposalItem[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([proposalVersionId, position])
}

model ProposalItem {
  id                String          @id @default(cuid())
  proposalSectionId String
  commercialItemId  String?
  name              String
  description       String?
  quantity          Float
  unitPrice         Float
  discountPercent   Float           @default(0)
  position          Int
  proposalSection   ProposalSection @relation(fields: [proposalSectionId], references: [id], onDelete: Cascade)
  commercialItem    CommercialItem? @relation(fields: [commercialItemId], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([proposalSectionId, position])
}

model ProposalPublicLink {
  id                String          @id @default(cuid())
  proposalVersionId String
  token             String          @unique
  expiresAt         DateTime?
  revokedAt         DateTime?
  accessCount       Int             @default(0)
  proposalVersion   ProposalVersion @relation(fields: [proposalVersionId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model ProposalAuditLog {
  id                String              @id @default(cuid())
  proposalId        String
  proposalVersionId String?
  userId            String?
  action            String
  message           String
  details           String?
  proposal          Proposal            @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  proposalVersion   ProposalVersion?    @relation(fields: [proposalVersionId], references: [id], onDelete: SetNull)
  user              User?               @relation("ProposalAuditLogUser", fields: [userId], references: [id], onDelete: SetNull)
  createdAt         DateTime            @default(now())
}
