generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model CommercialProfile {
  id                      String   @id @default(cuid())
  slug                    String   @unique
  name                    String
  maxFinalPriceAdjustment Int      @default(0)
  canManageCatalog        Boolean  @default(false)
  canManageProposals      Boolean  @default(false)
  canManageUsers          Boolean  @default(false)
  isSystem                Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  users                   User[]   @relation("CommercialProfileUsers")
}

model User {
  id                      String             @id @default(cuid())
  name                    String
  email                   String             @unique
  passwordHash            String
  status                  String             @default("ACTIVE")
  profileId               String
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  commercialItemsUpdated  CommercialItem[]   @relation("CommercialItemUpdatedBy")
  commercialItemsCreated  CommercialItem[]   @relation("CommercialItemCreatedBy")
  proposalsUpdated        Proposal[]         @relation("ProposalUpdatedBy")
  proposalsCreated        Proposal[]         @relation("ProposalCreatedBy")
  proposalAuditLogs       ProposalAuditLog[] @relation("ProposalAuditLogUser")
  proposalVersionsCreated ProposalVersion[]  @relation("ProposalVersionCreatedBy")
  salesGoals              SalesGoal[]        @relation("UserSalesGoal")
  profile                 CommercialProfile  @relation("CommercialProfileUsers", fields: [profileId], references: [id])
}

model CommercialItem {
  id                     String              @id @default(cuid())
  code                   String              @unique
  name                   String
  category               String
  subcategory            String              @default("Geral")
  type                   String
  unit                   String              @default("UN")
  baseCost               Float               @default(0)
  referencePrice         Float               @default(0)
  commercialDescription  String              @default("")
  operationalDescription String?
  manufacturer           String?
  model                  String?
  sku                    String?             @unique
  ean                    String?
  imageUrl               String?
  active                 Boolean             @default(true)
  catalogCategoryId      String?
  catalogSubcategoryId   String?
  createdById            String
  updatedById            String
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  updatedBy              User                @relation("CommercialItemUpdatedBy", fields: [updatedById], references: [id])
  createdBy              User                @relation("CommercialItemCreatedBy", fields: [createdById], references: [id])
  CatalogSubcategory     CatalogSubcategory? @relation(fields: [catalogSubcategoryId], references: [id])
  CatalogCategory        CatalogCategory?    @relation(fields: [catalogCategoryId], references: [id])
  proposalItems          ProposalItem[]
}

model Proposal {
  id              String             @id @default(cuid())
  number          String             @unique
  title           String
  customerName    String
  customerEmail   String?
  customerId      String?
  status          String             @default("DRAFT")
  currentRevision Int                @default(1)
  createdById     String
  updatedById     String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  updatedBy       User               @relation("ProposalUpdatedBy", fields: [updatedById], references: [id])
  createdBy       User               @relation("ProposalCreatedBy", fields: [createdById], references: [id])
  Customer        Customer?          @relation(fields: [customerId], references: [id])
  auditLogs       ProposalAuditLog[]
  versions        ProposalVersion[]
}

model ProposalVersion {
  id             String               @id @default(cuid())
  proposalId     String
  revisionNumber Int
  label          String
  status         String               @default("DRAFT")
  notes          String?
  createdById    String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  auditLogs      ProposalAuditLog[]
  publicLinks    ProposalPublicLink[]
  sections       ProposalSection[]
  createdBy      User                 @relation("ProposalVersionCreatedBy", fields: [createdById], references: [id])
  proposal       Proposal             @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@unique([proposalId, revisionNumber])
}

model ProposalSection {
  id                String          @id @default(cuid())
  proposalVersionId String
  title             String
  description       String?
  position          Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  systemName        String?
  items             ProposalItem[]
  proposalVersion   ProposalVersion @relation(fields: [proposalVersionId], references: [id], onDelete: Cascade)

  @@unique([proposalVersionId, position])
}

model ProposalItem {
  id                String          @id @default(cuid())
  proposalSectionId String
  commercialItemId  String?
  name              String
  description       String?
  quantity          Float
  unitPrice         Float
  discountPercent   Float           @default(0)
  position          Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  commercialItem    CommercialItem? @relation(fields: [commercialItemId], references: [id])
  proposalSection   ProposalSection @relation(fields: [proposalSectionId], references: [id], onDelete: Cascade)

  @@unique([proposalSectionId, position])
}

model ProposalPublicLink {
  id                String          @id @default(cuid())
  proposalVersionId String
  token             String          @unique
  expiresAt         DateTime?
  revokedAt         DateTime?
  accessCount       Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  proposalVersion   ProposalVersion @relation(fields: [proposalVersionId], references: [id], onDelete: Cascade)
}

model ProposalAuditLog {
  id                String           @id @default(cuid())
  proposalId        String
  proposalVersionId String?
  userId            String?
  action            String
  message           String
  details           String?
  createdAt         DateTime         @default(now())
  user              User?            @relation("ProposalAuditLogUser", fields: [userId], references: [id])
  proposalVersion   ProposalVersion? @relation(fields: [proposalVersionId], references: [id])
  proposal          Proposal         @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

model SalesGoal {
  id            String   @id @default(cuid())
  month         Int
  year          Int
  targetAmount  Float
  currentAmount Float    @default(0)
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User?    @relation("UserSalesGoal", fields: [userId], references: [id])

  @@unique([month, year, userId])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String   @default("INFO")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CatalogCategory {
  id                 String               @id
  name               String               @unique
  description        String?
  active             Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  CatalogSubcategory CatalogSubcategory[]
  CommercialItem     CommercialItem[]
}

model CatalogSubcategory {
  id              String           @id
  categoryId      String
  name            String
  description     String?
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime
  CatalogCategory CatalogCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  CommercialItem  CommercialItem[]

  @@unique([categoryId, name])
}

model Customer {
  id           String     @id
  type         String     @default("PJ")
  name         String
  email        String?
  phone        String?
  document     String?
  notes        String?
  zipCode      String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  Proposal     Proposal[]
}

model GlobalEnvironment {
  id        String   @id
  name      String   @unique
  isDefault Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model GlobalSystem {
  id        String   @id
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model PricingRule {
  id               String   @id
  name             String
  category         String   @default("")
  subcategory      String   @default("")
  marginMultiplier Float    @default(1.0)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime
}

model SiteVisit {
  id           String   @id
  customerName String
  address      String?
  date         DateTime
  status       String   @default("PLANNED")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}
